# ===========================================
# PHARMACY PLATFORM - ENVIRONMENT VARIABLES
# ===========================================
# Local setup: copy this file to `.env` in the project root (that file is gitignored).
# Put real secrets only in `.env` — never commit `.env` or `.env.local`.
# For Docker Compose, service hostnames below use stack names (e.g. postgres, redis);
# for JVM services running on your machine, point hosts at localhost instead.

# ==================== SECURITY ====================
# JWT Secret - MUST be at least 32 characters for HS256
# Generate with: openssl rand -base64 32
JWT_SECRET=pharmacySecureJWTSecretKey2024ForHS256Algorithm256Bits

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Jasypt Encryption Password
# Change this in production!
JASYPT_ENCRYPTOR_PASSWORD=changeMeInProduction

# ==================== PORTS ====================
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
CATALOG_SERVICE_PORT=8082
ORDERS_SERVICE_PORT=8083
ADMIN_SERVICE_PORT=8084

# ==================== INFRASTRUCTURE ====================
EUREKA_SERVER_URL=http://eureka:8761/eureka/
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=pharmacy
POSTGRES_PASSWORD=pharmacy123

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

ZIPKIN_URL=http://zipkin:9411

# ==================== EMAIL / SMTP ====================
# Leave MAIL_HOST empty for local/dev without SMTP (notifications skip outbound mail).
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
# Used with real SMTP (Gmail, SendGrid, etc.). For Mailpit demo below, set both to false.
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# --- Demo: Mailpit (fake inbox, no real email) ---
# docker compose up -d mailpit rabbitmq ... then set:
# MAIL_HOST=mailpit
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SMTP_AUTH=false
# MAIL_SMTP_STARTTLS=false
# Open http://localhost:8025 to read captured messages.

# ==================== RATE LIMITING ====================
RATE_LIMIT_AUTH=5
RATE_LIMIT_GENERAL=100
RATE_LIMIT_BURST=20
